# Интеграционные тесты гоняют настоящий PrismaClient против ОТДЕЛЬНОЙ базы.
# Имя БД ОБЯЗАНО заканчиваться на `_test` — иначе integration-setup упадёт
# (предохранитель против затирания dev/prod данных).
#
# Локально: создать базу один раз —
#   docker compose up -d db
#   docker compose exec db psql -U user -d natsdoll -c "CREATE DATABASE natsdoll_test;"
# затем `npm run test:int -w apps/api` (миграции накатятся автоматически).
DATABASE_URL=postgresql://user:password@127.0.0.1:5432/natsdoll_test
