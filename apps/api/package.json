{
  "name": "@natsdoll/api",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsup src/main.ts --format cjs --out-dir dist --no-splitting",
    "start": "node dist/main.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:int": "vitest run --config vitest.integration.config.ts",
    "test:ui": "vitest --ui",
    "lint": "eslint src --max-warnings=0",
    "generate": "prisma generate",
    "import:etsy": "tsx --env-file=.env scripts/import-etsy.ts",
    "backfill:image-cache": "tsx --env-file=.env scripts/backfill-image-cache-control.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@hono/node-server": "^1.11.1",
    "@hono/zod-validator": "^0.7.6",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/client": "^6.6.0",
    "@smithy/node-http-handler": "^4.7.4",
    "csv-parse": "^5.6.0",
    "googleapis": "^171.4.0",
    "hono": "^4.12.27",
    "jose": "^6.2.2",
    "p-limit": "^6.2.0",
    "resend": "^6.12.0",
    "sharp": "^0.34.5",
    "slugify": "^1.6.9",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "prisma": "^6.6.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^2.0.0"
  }
}
