# Редирект www → апекс. В боевом режиме WWW_ADDRESS=www.natsdoll.com — Caddy
# выпишет на www отдельный сертификат и 308-редиректит на апекс. На этапе «по IP»
# дефолт http://localhost:2080 делает блок инертным (без ACME, наружу не проброшен).
{$WWW_ADDRESS:http://localhost:2080} {
	redir https://{$SITE_ADDRESS::80}{uri} 308
}

{$SITE_ADDRESS::80} {
	encode gzip zstd

	header {
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		Content-Security-Policy "default-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: https://storage.yandexcloud.net https://*.paypal.com https://*.paypalobjects.com; connect-src 'self' https://stats.natsdoll.com https://*.paypal.com; script-src 'self' 'sha256-50W4WRXjQgOG7w1qTb51qD4r+v8PqffINSqRVdWnqPQ=' https://stats.natsdoll.com https://*.paypal.com https://*.paypalobjects.com; frame-src https://*.paypal.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self' https://*.paypal.com; object-src 'none';"
	}

	handle_path /api/* {
		request_body {
			max_size 26MiB
		}
		reverse_proxy api:3000 {
			# Перезаписываем X-Real-IP реальным адресом TCP-пира (Caddy — edge-прокси).
			# Без этого клиент мог бы прислать произвольный X-Real-IP и обойти rate limiter,
			# который доверяет этому заголовку (см. apps/api/src/shared/middleware/rateLimit.ts).
			header_up X-Real-IP {remote_host}
		}
	}

	handle {
		reverse_proxy web:3000
	}
}

pay.natsdoll.com {
	encode gzip zstd
	header {
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Strict-Transport-Security "max-age=63072000"
		X-Robots-Tag "noindex, nofollow"
	}
	@blocked path /wp-config.php* /xmlrpc.php
	respond @blocked 403
	reverse_proxy wordpress:80 {
		# Перезаписываем X-Real-IP реальным адресом TCP-пира (Caddy — edge-прокси).
		# Иначе клиент мог бы прислать произвольный X-Real-IP, и WooCommerce записал бы
		# поддельный IP плательщика в payIp (fraud-сигнал шлюза Authorize.Net).
		header_up X-Real-IP {remote_host}
	}
}

stats.natsdoll.com {
	header {
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Strict-Transport-Security "max-age=63072000"
	}
	reverse_proxy umami:3000
}
