# База данных
DB_USER=natsdoll
DB_PASSWORD=your_password_here
DB_NAME=natsdoll

# Приложение
NODE_ENV=production
FRONTEND_URL=https://your-domain.com
# Подпись JWT access-токена.
JWT_SECRET=your_long_random_secret_here
# HMAC-хеширование refresh- и email-verification-токенов перед записью в БД.
# Если не задан — fallback на JWT_SECRET. Рекомендуется задавать отдельно
# для defense-in-depth и независимой ротации.
HMAC_SECRET=different_long_random_secret_for_token_hashing

# Веб-сервер (Caddy)
# Этап 1 (проверка по IP): SITE_ADDRESS=:80 — чистый HTTP.
# Этап 2 (боевой): SITE_ADDRESS=natsdoll.com — Caddy выписывает сертификат Let's Encrypt.
SITE_ADDRESS=:80
# Редирект www → апекс. Этап 1: оставить пустым (дефолт инертен). Этап 2: WWW_ADDRESS=www.natsdoll.com.
WWW_ADDRESS=
# Email для уведомлений Let's Encrypt (необязательно).
ACME_EMAIL=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Яндекс Object Storage
YANDEX_S3_ACCESS_KEY=
YANDEX_S3_SECRET_KEY=
YANDEX_S3_BUCKET=
YANDEX_S3_ENDPOINT=

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Email (Resend)
RESEND_API_KEY=

# Admin (создаётся через prisma db seed; пропускается если не задано)
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Admin
