# База данных
DB_USER=natsdoll
DB_PASSWORD=your_password_here
DB_NAME=natsdoll

# Приложение
NODE_ENV=production
FRONTEND_URL=https://your-domain.com
# Подпись JWT access-токена.
JWT_SECRET=your_long_random_secret_here
# HMAC-хеширование refresh- и email-verification-токенов перед записью в БД.
# Если не задан — fallback на JWT_SECRET. Рекомендуется задавать отдельно
# для defense-in-depth и независимой ротации.
HMAC_SECRET=different_long_random_secret_for_token_hashing

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Яндекс Object Storage
YANDEX_S3_ACCESS_KEY=
YANDEX_S3_SECRET_KEY=
YANDEX_S3_BUCKET=
YANDEX_S3_ENDPOINT=

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Email (Resend)
RESEND_API_KEY=
